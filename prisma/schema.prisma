// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
  //  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE    // Мужские
  FEMALE  // Женские
  UNISEX  // Унисекс
}


// Фрагмент идеальной SEO-структуры в schema.prisma
model Brand {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique // Для URL: /catalog/casio
  metaTitle       String?
  metaDescription String?
  watches         Watch[]
}

model Category {
  id              String   @id @default(uuid())
  name            String   @unique // Например: "Кварцевые", "Дайверские"
  slug            String   @unique // Для URL: /catalog/quartz
  metaTitle       String?
  metaDescription String?
  watches         Watch[]
}

model Watch {
  id              String       @id @default(uuid())
  modelCode       String       @unique // GA-2100-1A1
  title           String       // Полное SEO-название
  slug            String       @unique 
  price           Int
  description     String
  imageUrl        String?      // Главное фото (оставляем для быстрых превью в каталоге)
  
  // --- НОВЫЕ ПОЛЯ ---
  images          WatchImage[] // Связь «один ко многим» для галереи
  model3dUrl      String?      // Опциональная ссылка на 3D-модель (формат .glb)
  gender          Gender       @default(UNISEX)
  // ------------------

  inStock         Boolean      @default(true)
  stockKaliningrad Int         @default(0) 
  
  brandId         String
  brand           Brand        @relation(fields: [brandId], references: [id])
  categoryId      String
  category        Category     @relation(fields: [categoryId], references: [id])

  metaTitle       String?
  metaDescription String?
  h1              String?
}

// Новая модель для галереи картинок
model WatchImage {
  id        String   @id @default(uuid())
  url       String?   // Ссылка на картинку
  alt       String?  // СВЕРХВАЖНО ДЛЯ SEO! Сюда будем писать "Часы Casio GA-2100-1A1 — вид сбоку"
  watchId   String
  watch     Watch    @relation(fields: [watchId], references: [id], onDelete: Cascade)
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique   // для красивых URL
  content   String   @db.Text  // HTML-контент
  excerpt   String?  // краткое описание
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}